NODE_ENV=development
PORT=3002
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3002

DATABASE_URL=mysql://lanmic:change-me@127.0.0.1:3306/lanmic

JWT_ACCESS_SECRET=replace-with-at-least-64-random-characters
JWT_ISSUER=lanmic-api
JWT_AUDIENCE=lanmic-web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_TOKEN_REMEMBER_TTL_SECONDS=2592000

TOKEN_PEPPER=replace-with-at-least-64-random-characters
OTP_PEPPER=replace-with-at-least-64-random-characters
CSRF_SECRET=replace-with-at-least-64-random-characters

COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
TRUST_PROXY_HOPS=1

ALLOW_PUBLIC_REGISTRATION=false
SWAGGER_ENABLED=true
SMTP_REQUIRED=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=LANMIC Polymers
CONTACT_RECIPIENT_EMAIL=contact@example.com

ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
